{
  "permissions": {
    "defaultMode": "default",
    "allow": [
      "Read(./**/*)",
      "Grep(./**/*)",
      "Glob(./**/*)",
      "Bash(git status -s)",
      "Bash(git status)",
      "Bash(git diff)",
      "Bash(git diff --staged)",
      "Bash(git diff --name-only)",
      "Bash(git diff --staged --name-only)",
      "Bash(git log --oneline)",
      "Bash(git log --oneline -10)",
      "Bash(git log --oneline -20)",
      "Bash(git show)",
      "Bash(git branch -a)",
      "Bash(git remote -v)",
      "Bash(git tag)",
      "Bash(git stash list)",
      "Bash(git ls-files)",
      "Bash(git rev-parse --show-toplevel)",
      "Bash(git rev-parse --abbrev-ref HEAD)",
      "Bash(git rev-parse HEAD)",
      "Bash(git config --list)",
      "Bash(git shortlog -sn)",
      "Bash(TZ='Asia/Seoul' date +\"%Y-%m-%d-%H%M%S\")"
    ],
    "deny": [
      "Read(./.env*)",
      "Read(./**/.env*)",
      "Read(./.git/config)",
      "Read(./**/.git/config)",
      "Read(./.git/hooks/*)",
      "Read(./**/.git/hooks/*)",
      "Read(./*.pem)",
      "Read(./**/*.pem)",
      "Read(./*.key)",
      "Read(./**/*.key)",
      "Read(./*.pfx)",
      "Read(./**/*.pfx)",
      "Read(./*.p12)",
      "Read(./**/*.p12)",
      "Read(./*.jks)",
      "Read(./**/*.jks)",
      "Read(./*.keystore)",
      "Read(./**/*.keystore)",
      "Read(./*.gpg)",
      "Read(./**/*.gpg)",
      "Read(./*.asc)",
      "Read(./**/*.asc)",
      "Read(./credentials*.json)",
      "Read(./**/credentials*.json)",
      "Read(./secrets*)",
      "Read(./**/secrets*)",
      "Read(./.npmrc)",
      "Read(./**/.npmrc)",
      "Read(./.git-credentials)",
      "Read(./**/.git-credentials)",
      "Read(~/.ssh/*)",
      "Read(~/.aws/*)",
      "Read(~/.kube/*)",
      "Read(~/.config/gcloud/*)",
      "Read(~/.gnupg/*)",
      "Read(~/.docker/*)",
      "Read(/etc/**)",
      "Grep(./.env*)",
      "Grep(./**/.env*)",
      "Grep(./.git/config)",
      "Grep(./**/.git/config)",
      "Grep(./.git/hooks/*)",
      "Grep(./**/.git/hooks/*)",
      "Grep(./*.pem)",
      "Grep(./**/*.pem)",
      "Grep(./*.key)",
      "Grep(./**/*.key)",
      "Grep(./*.pfx)",
      "Grep(./**/*.pfx)",
      "Grep(./*.p12)",
      "Grep(./**/*.p12)",
      "Grep(./*.jks)",
      "Grep(./**/*.jks)",
      "Grep(./*.keystore)",
      "Grep(./**/*.keystore)",
      "Grep(./*.gpg)",
      "Grep(./**/*.gpg)",
      "Grep(./*.asc)",
      "Grep(./**/*.asc)",
      "Grep(./credentials*.json)",
      "Grep(./**/credentials*.json)",
      "Grep(./secrets*)",
      "Grep(./**/secrets*)",
      "Grep(./.npmrc)",
      "Grep(./**/.npmrc)",
      "Grep(./.git-credentials)",
      "Grep(./**/.git-credentials)",
      "Grep(~/.ssh/*)",
      "Grep(~/.aws/*)",
      "Grep(~/.kube/*)",
      "Grep(~/.config/gcloud/*)",
      "Grep(~/.gnupg/*)",
      "Grep(~/.docker/*)",
      "Grep(/etc/**)",
      "Glob(./**/.env*)",
      "Glob(./**/credentials*.json)",
      "Glob(./**/secrets*)",
      "Glob(./**/.git-credentials)",
      "Glob(./.git/config)",
      "Glob(./**/.git/config)",
      "Glob(./.git/hooks/*)",
      "Glob(./**/.git/hooks/*)"
    ]
  },
  "language": "korean"
}
