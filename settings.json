{
  "permissions": {
    "defaultMode": "default",
    "allow": [
      "Read(./**/*)",
      "Grep(./**/*)",
      "Glob(./**/*)",
      "Bash(TZ='Asia/Seoul' date +\"%Y-%m-%d-%H%M%S\")",
      "Bash(git status)",
      "Bash(git diff)",
      "Bash(git diff --staged)",
      "Bash(git branch)",
      "Bash(git branch -a)",
      "Bash(git branch -v)"
    ],
    "deny": [
      "Read(./.env*)",
      "Read(./**/.env*)",
      "Read(./*.pem)",
      "Read(./**/*.pem)",
      "Read(./*.key)",
      "Read(./**/*.key)",
      "Read(./credentials*.json)",
      "Read(./**/credentials*.json)",
      "Read(./service-account*.json)",
      "Read(./**/service-account*.json)",
      "Read(./secrets*)",
      "Read(./**/secrets*)",
      "Read(./**/*.token)",
      "Read(./**/*.tfvars)",
      "Read(./.npmrc)",
      "Read(./**/.npmrc)",
      "Read(./.envrc)",
      "Read(./**/.envrc)",
      "Read(./.git-credentials)",
      "Read(./**/.git-credentials)",
      "Read(./.git/**)",
      "Read(~/.ssh/*)",
      "Read(~/.aws/*)",
      "Read(~/.kube/*)",
      "Read(/etc/**)",
      "Grep(./.env*)",
      "Grep(./**/.env*)",
      "Grep(./*.pem)",
      "Grep(./**/*.pem)",
      "Grep(./*.key)",
      "Grep(./**/*.key)",
      "Grep(./credentials*.json)",
      "Grep(./**/credentials*.json)",
      "Grep(./service-account*.json)",
      "Grep(./**/service-account*.json)",
      "Grep(./secrets*)",
      "Grep(./**/secrets*)",
      "Grep(./**/*.token)",
      "Grep(./**/*.tfvars)",
      "Grep(./.npmrc)",
      "Grep(./**/.npmrc)",
      "Grep(./.envrc)",
      "Grep(./**/.envrc)",
      "Grep(./.git-credentials)",
      "Grep(./**/.git-credentials)",
      "Grep(./.git/**)",
      "Grep(~/.ssh/*)",
      "Grep(~/.aws/*)",
      "Grep(~/.kube/*)",
      "Grep(/etc/**)"
    ]
  },
  "language": "korean"
}
