#!/bin/bash

CLAUDE_REPO="$(cd "$(dirname "$0")" && pwd)"
CLAUDE_HOME="$HOME/.claude"

echo "Comparing rules..."
diff -r "$CLAUDE_REPO/rules" "$CLAUDE_HOME/rules" 2>/dev/null || true
echo ""
echo "Comparing skills..."
diff -r "$CLAUDE_REPO/skills" "$CLAUDE_HOME/skills" 2>/dev/null || true
echo ""
echo "Comparing settings.json..."
diff "$CLAUDE_REPO/settings.json" "$CLAUDE_HOME/settings.json" 2>/dev/null || true
